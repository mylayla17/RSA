# Sovereign Reserve Agent - .env.local Setup Guide
# 
# IMPORTANT: This is an example file. Before running:
# 1. Rename this file to: .env.local
# 2. Edit the values below according to your needs
# 3. DO NOT commit .env.local to git (already in .gitignore)

# ==========================================
# REQUIRED for PRODUCTION MODE
# ==========================================

# Your wallet seed phrase (12 or 24 words)
# Get from:
# - MetaMask: Settings → Security & Privacy → Reveal Secret Recovery Phrase
# - Hardware wallet: Setup sheet on paper
# - Trezor/Ledger: Recovery card
#
# FORMAT: Space-separated words, example:
# SEED_PHRASE=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about
#
# ⚠️ IMPORTANT: Never share this seed phrase with anyone!
# ⚠️ This file is already in .gitignore, safe to store locally
# SEED_PHRASE=word1 word2 word3 ... word12

# ==========================================
# OPTIONAL: WDK Service Configuration
# ==========================================

# WDK blockchain service location
# Default: http://localhost:3001 (local development)
# Production: https://your-wdk-service.com
NEXT_PUBLIC_WDK_SERVICE_URL=http://localhost:3001

# ==========================================
# OPTIONAL: Node Environment
# ==========================================

NODE_ENV=development
# NODE_ENV=production  # Uncomment for production build

# ==========================================
# OPTIONAL: Logging
# ==========================================

LOG_LEVEL=info
# LOG_LEVEL=debug  # For detailed logs

# ==========================================
# OPTIONAL: Price Oracle
# ==========================================

# CoinGecko API (free, but has rate limits)
NEXT_PUBLIC_COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# If using CoinGecko Pro (higher rate limits):
# COINGECKO_PRO_API_KEY=your_pro_api_key_here

# ==========================================
# OPTIONAL: Analytics
# ==========================================

ENABLE_ANALYTICS=true
ENABLE_PROOF_OF_REASONING=true
