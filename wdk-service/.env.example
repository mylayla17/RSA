# WDK Service Environment Variables
# Copy this to .env.local and fill in your values

# REQUIRED: Your Ethereum wallet seed phrase (12 or 24 words)
# ⚠️ NEVER commit this to version control
# SEED_PHRASE=your 12 or 24 word seed phrase here

# Service Configuration
WDK_SERVICE_PORT=3001
NODE_ENV=development

# RPC Endpoints (optional - defaults provided)
# Ethereum Mainnet
ETH_RPC=https://eth.drpc.org

# Plasma (USDT0 optimized, recommended for x402)
PLASMA_RPC=https://rpc.plasma.to

# Stable (USDT0 optimized, recommended for x402)
STABLE_RPC=https://rpc.stable.xyz

# Bridge Configuration
BRIDGE_MAX_FEE=100000000000000

# Logging
LOG_LEVEL=debug

# x402 Payment Protocol
X402_FACILITATOR_URL=https://x402.semanticpay.io/

# Optional: Your seller address for x402 payments
# SELLER_ADDRESS=0x...

# Optional: Facilitator mnemonic (if running self-hosted x402 facilitator)
# FACILITATOR_MNEMONIC=your 12 or 24 word seed phrase
