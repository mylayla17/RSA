# ========================================================================
# SOVEREIGN RESERVE AGENT - Environment Configuration for Real Usage
# ========================================================================
# This file contains REAL BLOCKCHAIN CONFIGURATION
# ⚠️  NEVER commit this file to version control!
# ⚠️  .env.local is in .gitignore for security
# ========================================================================

# ========================================================================
# SECTION 1: NEXT.JS FRONTEND
# ========================================================================

# Environment: development or production
NODE_ENV=production

# Frontend port (default: 3000)
PORT=3000

# ========================================================================
# SECTION 2: WDK BLOCKCHAIN SERVICE (REAL OPERATIONS)
# ========================================================================

# URL where WDK Service is running
# For real blockchain operations: Start WDK service first
# Terminal 1: npm run wdk:service:dev
# Terminal 2: npm run dev
NEXT_PUBLIC_WDK_SERVICE_URL=http://localhost:3001

# ========================================================================
# SECTION 3: BLOCKCHAIN WALLET (BIP39 SEED PHRASE)
# ========================================================================

# ⚠️  CRITICAL: Your 12 or 24-word BIP39 seed phrase
# ⚠️  This is the ONLY thing needed for wallet access
# ⚠️  NEVER share or commit this!
# ⚠️  Keep backup in secure location
# 
# Format: word1 word2 word3 ... word12 (or 24 words)
# This seed phrase will derive:
#   - Ethereum wallet
#   - Arbitrum wallet  
#   - Optimism wallet
#   - Polygon wallet
#   - Plasma wallet
#   - Stable wallet
#
SRA_SEED_PHRASE=word word word word word word word word word word word word word

# Default blockchain chain for operations
# Options: ethereum, arbitrum, optimism, polygon, plasma, stable
# Default: ethereum (most liquidity for Velora DEX)
SRA_DEFAULT_CHAIN=ethereum

# Custom RPC endpoints (optional - defaults provided)
# Leave empty to use public RPC endpoints
# For better reliability, use your own RPC provider:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://www.infura.io/
# - QuickNode: https://www.quicknode.com/

# Ethereum Mainnet RPC
# SRA_ETH_RPC_URL=https://eth.drpc.org

# Arbitrum One RPC
# SRA_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optimism Mainnet RPC
# SRA_OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Polygon Mainnet RPC
# SRA_POLYGON_RPC_URL=https://polygon.llamarpc.com

# Tether Plasma RPC (USDT0 optimized)
# SRA_PLASMA_RPC_URL=https://rpc.plasma.to

# Tether Stable RPC (USDT0 optimized)
# SRA_STABLE_RPC_URL=https://rpc.stable.xyz

# ========================================================================
# SECTION 4: AI/LLM CONFIGURATION
# ========================================================================

# Using z-ai-web-dev-sdk (FREE - no API key needed!)
# AI reasoning works automatically with Tether's free z-ai service

# Optional: Use custom LLM endpoint
# Uncomment to override and use your own LLM (e.g., OpenAI, Anthropic)
# SRA_LLM_MODE=PRODUCTION
# SRA_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# SRA_LLM_API_KEY=sk-your-api-key-here
# SRA_LLM_MODEL=gpt-4

# ========================================================================
# SECTION 5: MARKET DATA (PRICE ORACLE)
# ========================================================================

# CoinGecko Pricing API (FREE tier available)
# For free tier: ~10-50 requests/minute
# For Pro: Higher rate limits and historical data

NEXT_PUBLIC_COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# Optional: CoinGecko Pro API key for higher rate limits
# Get key at: https://www.coingecko.com/en/api/pricing
# COINGECKO_PRO_API_KEY=

# ========================================================================
# SECTION 6: LOGGING & DEBUGGING
# ========================================================================

# Logging level: error, warn, info, debug, trace
LOG_LEVEL=info

# Enable detailed decision logs from OpenClawEngine
ENABLE_DECISION_LOGS=true

# ========================================================================
# QUICK START CHECKLIST
# ========================================================================
# 
# 1. ✓ Copy this file from .env.example → .env.local
# 2. ⚠️  Add your BIP39 seed phrase to SRA_SEED_PHRASE
# 3. ⚠️  Keep .env.local PRIVATE (in .gitignore)
# 4. ⚠️  Test with small amounts first
# 5. Start WDK Service: npm run wdk:service:dev (Terminal 1)
# 6. Start Frontend: npm run dev (Terminal 2)
# 7. Open http://localhost:3000
#
# ========================================================================