# Sovereign Reserve Agent Environment Configuration
# Copy from .env.example and fill in your values

# ============================================
# LLM CONFIGURATION
# ============================================

# Mode: DEMO (free AI) or PRODUCTION (custom endpoint)
SRA_LLM_MODE=DEMO

# For PRODUCTION mode, provide your LLM endpoint:
# SRA_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# SRA_LLM_API_KEY=sk-your-api-key-here
# SRA_LLM_MODEL=gpt-4

# ============================================
# WDK CONFIGURATION (for real swaps)
# ============================================

# Your wallet seed phrase (12-24 words)
# WARNING: Never commit real seed phrases to git!
# SRA_SEED_PHRASE=word1 word2 word3 ... word12

# Ethereum RPC URL (Alchemy, Infura, or public)
# SRA_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Port (default: 3000)
# PORT=3000

# Node environment
# NODE_ENV=development