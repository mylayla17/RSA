{
  "name": "sovereign-reserve-agent",
  "version": "2.0.0",
  "description": "Autonomous DeFi Agent for USDt/XAUt Liquidity Rebalancing - DoraHacks Galactica 2026",
  "private": true,
  "author": "Sovereign Reserve Team",
  "license": "MIT",
  "keywords": [
    "defi",
    "tether",
    "usdt",
    "xaut",
    "autonomous-agent",
    "ai-trading",
    "liquidity-management",
    "blockchain",
    "ethereum",
    "dorahacks",
    "galactica-2026",
    "wdk"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "wdk:service:dev": "cd wdk-service && npm run dev",
    "wdk:service:build": "cd wdk-service && npm run build",
    "wdk:service:start": "cd wdk-service && npm run start",
    "wdk:service:install": "cd wdk-service && npm install",
    "wdk:full-dev": "concurrently \"npm run dev\" \"npm run wdk:service:dev\" --names \"next,wdk\""
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.359.0",
    "next": "14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "z-ai-web-dev-sdk": "^0.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
