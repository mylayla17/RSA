# Sovereign Reserve Agent Environment Configuration
# Copy this file to .env.local and fill in your values

# =====================================
# NEXT.JS FRONTEND
# =====================================

# Next.js Environment (development or production)
NODE_ENV=development

# =====================================
# WDK BLOCKCHAIN SERVICE (REAL INTEGRATION)
# =====================================

# URL of the WDK blockchain service for real blockchain operations
# Default: http://localhost:3001 (local development)
# To use real blockchain: Start WDK service first (npm run wdk:service:dev)
NEXT_PUBLIC_WDK_SERVICE_URL=http://localhost:3001

# Your wallet seed phrase (12 or 24 BIP39 words)
# IMPORTANT: Never commit this to version control!
# Only add to .env.local (which is in .gitignore)
# Leave empty for DEMO mode (simulated swaps, no blockchain)
# SRA_SEED_PHRASE=word1 word2 word3 ... word12

# Optional: RPC URL for blockchain connection
# Defaults are provided, but you can override:
# SRA_RPC_URL=https://eth.drpc.org

# =====================================
# LLM CONFIGURATION
# =====================================

# Using z-ai-web-dev-sdk (free - no API key needed!)
# The AI model inference works out of the box with Tether's z-ai service

# Optional: Custom LLM endpoint (uncomment to override)
# SRA_LLM_MODE=PRODUCTION
# SRA_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# SRA_LLM_API_KEY=sk-your-api-key-here
# SRA_LLM_MODEL=gpt-4

# =====================================
# PRICE ORACLE
# =====================================

# CoinGecko API (free tier, rate-limited)
# Leave default for free tier, or use Pro API for higher limits
NEXT_PUBLIC_COINGECKO_API_BASE=https://api.coingecko.com/api/v3
# COINGECKO_PRO_API_KEY=your_pro_api_key_here

# =====================================
# LOGGING & DEBUGGING
# =====================================

# Application log level
LOG_LEVEL=info

# Enable detailed AI agent logging
DEBUG_AGENT=false

# Enable proof-of-reasoning audit trail
ENABLE_PROOF_OF_REASONING=true

# =====================================
# OPTIONAL SETTINGS
# ========================================

# Server port (default: 3000)
# PORT=3000

# Enable transaction analytics
ENABLE_ANALYTICS=true

# =====================================
# QUICK START GUIDE
# =====================================

# 🎯 FOR DEMO MODE (Default - No Blockchain):
# - Leave SEED_PHRASE commented out
# - Run: npm run dev
# - Swaps are simulated, no blockchain calls
# 
# 🔗 FOR REAL BLOCKCHAIN (Requires WDK Service):
# 1. Copy this file to .env.local
# 2. Add your SEED_PHRASE (12 or 24 words)
# 3. Start WDK service: npm run wdk:service:dev
# 4. Start Next.js: npm run dev
# 5. Dashboard will show REAL blockchain transactions
#
# ⚠️ SECURITY REMINDER:
# - Never commit .env.local to git
# - .env.local is in .gitignore for your safety
# - Use environment variables on production servers
# - Store secrets in secure vaults, not files

# =====================================
# REFERENCES
# =====================================

# WDK Documentation: https://docs.wdk.tether.io/
# WDK Service Setup: ./wdk-service/README.md
# Agent Skills: https://docs.wdk.tether.io/ai/agent-skills
# x402 Protocol: https://www.x402.org/
